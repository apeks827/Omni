{
  "name": "omni",
  "version": "1.0.0",
  "description": "Omni task manager",
  "private": true,
  "scripts": {
    "dev": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "typecheck": "tsc --project client/tsconfig.json --noEmit",
    "server": "tsx watch src/server.ts",
    "server:build": "tsc --project tsconfig.server.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apeks827/Omni.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/apeks827/Omni/issues"
  },
  "homepage": "https://github.com/apeks827/Omni#readme",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "react-window": "^2.2.7",
    "tsx": "^4.20.5",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^10.4.0-alpha.5",
    "@storybook/addon-docs": "^10.4.0-alpha.5",
    "@storybook/addon-onboarding": "^10.4.0-alpha.5",
    "@storybook/addon-vitest": "^10.4.0-alpha.5",
    "@storybook/react-vite": "^10.4.0-alpha.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.6.1",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-storybook": "^10.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "storybook": "^10.4.0-alpha.5",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
