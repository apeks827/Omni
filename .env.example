DB_HOST=localhost
DB_PORT=5432
DB_NAME=omni
DB_USER=postgres
DB_PASSWORD=

# JWT_SECRET must be a cryptographically secure random string (minimum 256 bits / 32 bytes)
# Generate with: openssl rand -hex 32
# WARNING: Never use default values in production!
JWT_SECRET=
PORT=3000
NODE_ENV=development

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

AI_API_URL=http://127.0.0.1:20128/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=simple-tasks

NLP_LLM_ENABLED=false

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=notifications@example.com
EMAIL_PASS=
EMAIL_FROM=Omni <notifications@example.com>

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

APP_URL=http://localhost:3000

# Logging
# Options: trace, debug, info, warn, error, fatal
# In production, set to 'info' or 'warn'
LOG_LEVEL=debug
